{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "offline-audio-journal",
  "version": "0.1.0",
  "identifier": "com.enticies.offline-audio-journal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "offline-audio-journal",
        "width": 800,
        "height": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [

    ]
  }
}
